{
  "realm": "mcdr",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "roles": {
    "realm": [
      { "name": "owner", "description": "Company owner who submits settlement requests" },
      { "name": "backoffice_employee", "description": "MCDR employee who reviews requests" }
    ]
  },
  "clients": [
    {
      "clientId": "mcdr-backend",
      "enabled": true,
      "publicClient": false,
      "secret": "change-me",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"]
    }
  ],
  "users": [
    {
      "username": "test.owner",
      "email": "test.owner@example.com",
      "firstName": "Test",
      "lastName": "Owner",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "Owner123!", "temporary": false }
      ],
      "realmRoles": ["owner"]
    },
    {
      "username": "test.employee",
      "email": "test.employee@example.com",
      "firstName": "Test",
      "lastName": "Employee",
      "enabled": true,
      "emailVerified": true,
      "credentials": [
        { "type": "password", "value": "Employee123!", "temporary": false }
      ],
      "realmRoles": ["backoffice_employee"]
    }
  ]
}
