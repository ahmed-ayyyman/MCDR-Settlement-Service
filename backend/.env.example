PORT=3000

# Mongo container name is "mongo" inside the docker-compose network —
# from your host machine (outside Docker) it would be localhost instead.
MONGO_URI=mongodb://mongo:27017/mcdr

# Keycloak — filled in after the realm import runs (see keycloak/realm-export.json)
KEYCLOAK_AUTH_SERVER_URL=http://keycloak:8080
KEYCLOAK_REALM=mcdr
KEYCLOAK_CLIENT_ID=mcdr-backend
KEYCLOAK_SECRET=change-me
