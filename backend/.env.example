PORT=3000

# Mongo container name is "mongo" inside the docker-compose network —
# from your host machine (outside Docker) it would be localhost instead.
MONGO_URI=mongodb://mongo:27017/mcdr

# Keycloak — filled in after the realm import runs (see keycloak/realm-export.json)
KEYCLOAK_AUTH_SERVER_URL=http://keycloak:8080
KEYCLOAK_REALM=mcdr
KEYCLOAK_CLIENT_ID=mcdr-backend
KEYCLOAK_SECRET=change-me

# JWT validation — issuer is typically <KEYCLOAK_AUTH_SERVER_URL>/realms/<KEYCLOAK_REALM>
# audience is typically the Keycloak client id
# JWT validation — issuer must match the "iss" claim in Keycloak tokens.
# When Keycloak is reached via localhost:8081 the issuer will be:
JWT_ISSUER=http://localhost:8081/realms/mcdr
# Optional: only set JWT_AUDIENCE if your Keycloak client is configured
# to add a custom audience. By default Keycloak uses "account".
# JWT_AUDIENCE=mcdr-backend
